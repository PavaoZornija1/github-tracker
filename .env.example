# HTTP
HTTP_ADDR=:8080

# Environment: development|local|test enable Ent Schema.Create; production skips it
APP_ENV=development

# PostgreSQL
DATABASE_URL=postgres://tracker:tracker@localhost:5432/tracker?sslmode=disable

# Redis (cache + single-flight locks only — not the job queue)
REDIS_URL=redis://localhost:6379/0

# RabbitMQ (async refresh jobs)
# Retry queue is derived as RABBITMQ_QUEUE + ".retry" (e.g. repo.refresh.retry)
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RABBITMQ_QUEUE=repo.refresh
RABBITMQ_DLQ=repo.refresh.dlq
RABBITMQ_EXCHANGE=repo.jobs
RABBITMQ_DLX=repo.jobs.dlx

# Worker
WORKER_CONCURRENCY=5
WORKER_MAX_RETRIES=3

# GitHub (optional — higher rate limits when set)
GITHUB_TOKEN=
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_HTTP_TIMEOUT=10s

# Cache
GITHUB_CACHE_TTL=5m
GITHUB_FETCH_LOCK_TTL=30s

# Logging
LOG_LEVEL=info
